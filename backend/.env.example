# Database (required)
#
# Supabase + Prisma: use the Transaction pooler (IPv4), NOT "Session mode", or you will
# hit "MaxClientsInSessionMode: max clients reached". In Supabase Dashboard → Connect:
# copy the "Transaction pooler" URI (port 6543) and add:
#   ?pgbouncer=true&connection_limit=1
# For `prisma migrate`, use "Direct connection" (port 5432) — set as DIRECT_URL in
# prisma/schema.prisma if you add it, or run migrations from a machine using the direct URL.
#
# Example (transaction pooler — use for the running API server):
# DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabase (required for auth)
# Get these from https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Anon key for auth operations (optional; falls back to service key)
SUPABASE_ANON_KEY=your-anon-key

# Database (required)
#
# --- Recommended split for Supabase + Prisma ---
#
# 1) DATABASE_URL — Transaction pooler (for the running Express API + Prisma Client at runtime).
#    Dashboard → Connect → "Transaction pooler" (port 6543). Append:
#      ?pgbouncer=true&connection_limit=1
#
# 2) DIRECT_URL — Direct connection (for `prisma migrate`, `db push`, introspection).
#    Dashboard → Connect → "Direct connection" (host db.<project>.supabase.co, port 5432).
#    Always include: ?sslmode=require
#
# If you omit DIRECT_URL, `prisma.config.ts` falls back to DATABASE_URL for migrations
# (using the pooler for migrate can hang on DDL — prefer setting DIRECT_URL).
#
# If port 5432 is blocked on your network (P1001), try another network (e.g. hotspot) or run migrate from CI.
#
# Example pooler (app runtime):
# DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Example direct (migrations) — password same as in Supabase Database settings:
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
#
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

# Supabase (required for auth)
# Get these from https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Anon key for auth operations (optional; falls back to service key)
SUPABASE_ANON_KEY=your-anon-key

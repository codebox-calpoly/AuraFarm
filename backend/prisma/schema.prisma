datasource db {
  provider = "postgresql"
  /// Supabase: use the **Transaction** pooler URI + `?pgbouncer=true&connection_limit=1`.
  /// Do not use Session mode for Prisma — you will hit MaxClientsInSessionMode.
  /// For migrations, set DIRECT_URL in root `.env` — see `prisma.config.ts` (not required in this file).
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  user
  admin
}

enum ChallengeReviewStatus {
  pending
  approved
  rejected
}

/// Tags for discovery filters; a challenge can have multiple.
enum ChallengeCategory {
  sports
  outdoors
  clubs
  campus
  beach
  volunteering
  arts_culture
  misc
}

model User {
  id              Int                   @id @default(autoincrement())
  supabaseId      String?               @unique
  email           String                @unique
  name            String
  role            UserRole              @default(user)
  auraPoints      Int                   @default(0)
  streak          Int                   @default(0)
  lastCompletedAt DateTime? // For streak tracking
  /// When false, approved completions are hidden from global and friends feeds (own profile still lists them).
  shareCompletionsInFeed Boolean         @default(true)
  createdAt       DateTime              @default(now())
  completions     ChallengeCompletion[] // Reverse relation
  likes           CompletionLike[]      // Reverse relation
  flags           Flag[] // Flags they've submitted
  friendshipsSent     Friendship[]      @relation("FriendshipRequester")
  friendshipsReceived Friendship[]      @relation("FriendshipAddressee")

  @@index([auraPoints])
}

enum FriendshipStatus {
  pending
  accepted
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Challenge {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  /// Newline-separated lines; shown as photo submission guidelines
  photoGuidelines String                @default("")
  latitude        Float
  longitude       Float
  difficulty      String
  pointsReward    Int
  /// One or more theme tags (filters match if any tag matches).
  tags            ChallengeCategory[]
  createdAt       DateTime              @default(now())
  completions  ChallengeCompletion[] // Reverse relation

  @@index([latitude, longitude])
  @@index([createdAt])
  @@index([difficulty])
  @@index([tags], type: Gin)
}

model ChallengeCompletion {
  id           Int                   @id @default(autoincrement())
  userId       Int
  challengeId  Int
  latitude     Float
  longitude    Float
  imageUrl     String?
  caption      String?
  completedAt  DateTime              @default(now())
  /// Moderation queue: new submissions start as pending; public feed shows approved only.
  reviewStatus ChallengeReviewStatus @default(pending)
  reviewedAt   DateTime?
  /// When the post became visible on the public feed (set when approved).
  postedAt     DateTime?
  user         User                  @relation(fields: [userId], references: [id])
  challenge    Challenge             @relation(fields: [challengeId], references: [id])
  flags        Flag[] // Flags on this completion
  likeRecords  CompletionLike[]
  imageUri     String
  likes        Int                   @default(0)

  @@unique([userId, challengeId]) // Prevent duplicate completions
  @@index([userId]) // Index for faster user completion queries
  @@index([challengeId]) // Index for faster challenge completion queries
  @@index([completedAt])
  @@index([userId, completedAt])
  @@index([reviewStatus, completedAt])
}

model CompletionLike {
  id           Int       @id @default(autoincrement())
  completionId Int
  userId       Int
  createdAt    DateTime  @default(now())
  completion   ChallengeCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([completionId, userId])
  @@index([completionId])
  @@index([userId])
}

model Flag {
  id           Int                 @id @default(autoincrement())
  completionId Int
  flaggedById  Int
  reason       String?
  createdAt    DateTime            @default(now())
  completion   ChallengeCompletion @relation(fields: [completionId], references: [id])
  flaggedBy    User                @relation(fields: [flaggedById], references: [id])

  @@unique([completionId, flaggedById]) // Prevent duplicate flags from same user
  @@index([completionId]) // Index for faster completion flag queries
  @@index([flaggedById]) // Index for faster user flag queries
}

/// One row per email currently going through OTP verification.
/// Created on signup / resend, deleted on success or expiry.
model EmailVerification {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, expiresAt])
}
